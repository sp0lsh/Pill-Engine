#!/usr/bin/bash

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

mapfile -t RS < <(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.rs$' || true)
[[ ${#RS[@]} -eq 0 ]] && exit 0

command -v rustfmt >/dev/null || { echo "rustfmt missing: rustup componend add rustfmt"  >&2; exit 1; }

rustfmt --edition 2021 "${RS[@]}"
git add -- "${RS[@]}"
